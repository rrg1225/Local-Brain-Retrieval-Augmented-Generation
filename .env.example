# ==========================================
# 第二大脑 (bendiRAG) — 环境配置模板
# ==========================================
# 复制此文件为 .env 并填入你的真实配置值。
# .env 已在 .gitignore 中排除，不会提交到 Git。
# ==========================================

# --- Gemini API Key（Google AI Studio 或 Vertex AI）---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Cloudflare Worker 代理根地址（无尾部斜杠）---
# 若无 Worker 代理，可留空，SDK 会直连 Google API
PROXY_URL=https://your-worker.your-subdomain.workers.dev

# --- 本地 HTTP/S 隧道代理（Clash / v2ray 等）---
# 设置后会写入 HTTP_PROXY、HTTPS_PROXY 及小写形式
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# --- 阿里云 DashScope / 百炼 API Key（通义千问对话）---
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# --- Google 官方 SDK 兼容（可选；不设置时程序会将 GEMINI_API_KEY 同步到 GOOGLE_API_KEY）---
# GOOGLE_API_KEY=

# --- 工作区：逗号分隔的绝对或相对路径，将监听并增量索引 ---
WORKSPACE_PATHS=./workspace

# --- Chroma 向量库持久化目录 ---
CHROMA_PERSIST_DIR=./.chroma_second_brain

# --- LLM 模型 ---
GEMINI_LLM_MODEL=gemini-2.5-flash

# --- 本地 HuggingFace Embedding / Rerank 模型 ---
LOCAL_EMBED_MODEL=BAAI/bge-large-zh-v1.5
LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- HuggingFace / Transformers 模型缓存目录 ---
# 留空使用系统默认；可指定到空间较大的盘符
HF_HOME=
SENTENCE_TRANSFORMERS_HOME=
LLAMA_INDEX_CACHE_DIR=
TRANSFORMERS_CACHE=

# --- 遥测（设为 False 禁用 LlamaIndex 遥测）---
ANONYMIZED_TELEMETRY=False

# --- RAG 切块参数 ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# --- 文件监听防抖（秒）：同一轮修改在静默这么久后才触发增量索引 ---
DEBOUNCE_SECONDS=60

# --- 多轮对话记忆 Token 上限 ---
MEMORY_TOKEN_LIMIT=8192
